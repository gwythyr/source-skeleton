{
  "name": "source-skeleton",
  "version": "0.1.0",
  "description": "Generate collapsed skeleton views of TypeScript/JavaScript files for AI coding agents",
  "bin": {
    "source-skeleton": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
