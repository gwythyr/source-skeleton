{
  "name": "source-skeleton",
  "version": "0.1.3",
  "description": "Generate collapsed skeleton views of TypeScript/JavaScript files for AI coding agents",
  "type": "module",
  "bin": {
    "source-skeleton": "dist/cli.js",
    "source-skeleton-mcp": "dist/mcp-bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/ test/",
    "check": "tsc --noEmit -p tsconfig.test.json",
    "ci": "npm run check && npm run lint && npm test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ast",
    "skeleton",
    "typescript",
    "code-analysis",
    "ai",
    "coding-agent",
    "claude-code",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Victor Shymko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwythyr/source-skeleton.git"
  },
  "homepage": "https://github.com/gwythyr/source-skeleton#readme",
  "bugs": {
    "url": "https://github.com/gwythyr/source-skeleton/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@ast-grep/napi": "^0.42.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  }
}
