  },
  "keywords": ["ast", "skeleton", "typescript", "code-analysis", "ai", "coding-agent"],
  "license": "MIT",
  "files": ["dist/", "README.md", "LICENSE"],
  "dependencies": {
    "@ast-grep/napi": "^0.42.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
