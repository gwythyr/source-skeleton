#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: source-skeleton <file.ts|file.js>" >&2
  exit 1
fi

FILE="$1"
RULES="/Users/victorshymko/.pi/bin/skeleton-rules-deep.yml"

if [[ ! -f "$FILE" ]]; then
  echo "File not found: $FILE" >&2
  exit 1
fi

if ! command -v sg >/dev/null 2>&1; then
  echo "ast-grep (sg) is required. Install with: brew install ast-grep" >&2
  exit 1
fi

if [[ ! -f "$RULES" ]]; then
  echo "Rules file not found: $RULES" >&2
  exit 1
fi

TMP_DIR="$(mktemp -d /tmp/skeleton.XXXXXX)"
TMP_FILE="$TMP_DIR/source.ts"
CALLS_JSON="$TMP_DIR/calls.json"
trap 'rm -rf "$TMP_DIR"' EXIT
cp "$FILE" "$TMP_FILE"

# Extract call expressions from original file (member expressions like this.foo.bar())
sg run --pattern '$OBJ.$METHOD($$$ARGS)' -l typescript "$FILE" --json 2>/dev/null > "$CALLS_JSON" || echo '[]' > "$CALLS_JSON"

# Collapse method/function bodies
sg scan -r "$RULES" "$TMP_FILE" --update-all >/dev/null 2>&1 || true

# Process skeleton and annotate with external calls
python3 - "$FILE" "$TMP_FILE" "$CALLS_JSON" <<'PY'
import difflib
import json
import re
import sys

orig_path, skel_path, calls_json_path = sys.argv[1], sys.argv[2], sys.argv[3]

with open(orig_path, "r", encoding="utf-8", errors="replace") as f:
    orig_text = f.read()
    orig = orig_text.splitlines()
with open(skel_path, "r", encoding="utf-8", errors="replace") as f:
    skel = f.read().splitlines()
with open(calls_json_path, "r", encoding="utf-8", errors="replace") as f:
    try:
        calls_data = json.load(f)
    except json.JSONDecodeError:
        calls_data = []

# Parse imports to find external identifiers
import_pattern = re.compile(
    r'import\s+(?:type\s+)?'
    r'(?:'
    r'(\w+)'                           # default import
    r'|'
    r'\{([^}]+)\}'                     # named imports
    r'|'
    r'\*\s+as\s+(\w+)'                 # namespace import
    r')'
    r'(?:\s*,\s*\{([^}]+)\})?'         # additional named imports after default
    r'\s+from\s+["\']([^"\']+)["\']',
    re.MULTILINE
)

external_identifiers = set()
for match in import_pattern.finditer(orig_text):
    default_import, named_imports, namespace_import, additional_named, module_path = match.groups()
    
    if default_import:
        external_identifiers.add(default_import)
    if namespace_import:
        external_identifiers.add(namespace_import)
    for named in [named_imports, additional_named]:
        if named:
            for part in named.split(','):
                part = part.strip()
                if ' as ' in part:
                    part = part.split(' as ')[1].strip()
                if part.startswith('type '):
                    part = part[5:].strip()
                if part:
                    external_identifiers.add(part)

# Capture constructor-injected dependencies (this.xxx patterns)
ctor_param_pattern = re.compile(
    r'(?:private|readonly|public)\s+(?:readonly\s+)?(\w+)\s*[,:)]',
    re.MULTILINE
)
injected_services = set()
for match in ctor_param_pattern.finditer(orig_text):
    injected_services.add(match.group(1))

# Parse call expressions and map to lines
calls_by_line = {}
for call in calls_data:
    if not isinstance(call, dict):
        continue
    
    text = call.get("text", "")
    range_info = call.get("range", {})
    start = range_info.get("start", {})
    line_1indexed = start.get("line", 0)
    
    if line_1indexed <= 0:
        continue
    
    paren_idx = text.find('(')
    if paren_idx > 0:
        callee = text[:paren_idx]
    else:
        callee = text
    
    callee_parts = callee.replace('this.', '').split('.')
    first_part = callee_parts[0] if callee_parts else ''
    
    is_service_call = first_part in injected_services
    is_external_call = first_part in external_identifiers
    
    if is_service_call or is_external_call:
        if line_1indexed not in calls_by_line:
            calls_by_line[line_1indexed] = []
        simplified = callee
        if simplified.startswith('this.'):
            simplified = simplified[5:]
        if simplified not in calls_by_line[line_1indexed]:
            calls_by_line[line_1indexed].append(simplified)

# Build skeleton labels using difflib
labels = [None] * len(skel)
sm = difflib.SequenceMatcher(a=orig, b=skel, autojunk=False)

for tag, a0, a1, b0, b1 in sm.get_opcodes():
    a_len = a1 - a0
    b_len = b1 - b0

    if tag == "equal":
        for i in range(b_len):
            labels[b0 + i] = str(a0 + i + 1)

    elif tag == "replace":
        if b_len <= 0:
            continue
        if a_len <= 0:
            anchor = a0 if a0 > 0 else 1
            for i in range(b_len):
                labels[b0 + i] = str(anchor)
        elif a_len == b_len:
            for i in range(b_len):
                labels[b0 + i] = str(a0 + i + 1)
        else:
            range_label = f"{a0 + 1}-{a1}"
            for i in range(b_len):
                labels[b0 + i] = range_label

    elif tag == "insert":
        anchor = a0 if a0 > 0 else 1
        for i in range(b_len):
            labels[b0 + i] = str(anchor)

prev = "1"
for i, label in enumerate(labels):
    if label is None:
        labels[i] = prev
    else:
        prev = label

# Detect collapsed lines and map external calls by their original line range label
collapsed_marker = re.compile(r'\{\s*/\*\s*\.\.\.\s*\*/\s*\}')

def parse_line_range(label):
    """Parse labels like '7' or '7-11' into (start, end)."""
    if '-' in label:
        start, end = label.split('-', 1)
        return int(start), int(end)
    n = int(label)
    return n, n

# Map skeleton line index -> list of external calls for that collapsed block
skeleton_calls = {}

for idx, line in enumerate(skel):
    if not collapsed_marker.search(line):
        continue

    try:
        start_line, end_line = parse_line_range(labels[idx])
    except (ValueError, TypeError, IndexError):
        continue

    calls_in_range = []
    for line_num in range(start_line, end_line + 1):
        calls_in_range.extend(calls_by_line.get(line_num, []))

    # Dedupe while preserving order
    seen = set()
    unique_calls = []
    for c in calls_in_range:
        if c not in seen:
            seen.add(c)
            unique_calls.append(c)

    if unique_calls:
        skeleton_calls[idx] = unique_calls

# Output
for idx, (label, line) in enumerate(zip(labels, skel)):
    # Keep output compact: use start line only when label is a range (e.g. "7-11" -> "7")
    display_label = label.split('-', 1)[0]

    if line.strip():
        sys.stdout.write(f"{display_label}\t{line}\n")
    else:
        # Preserve blank lines with their original line number
        sys.stdout.write(f"{display_label}\n")

    # If this line is a collapsed method, show its external calls
    if idx in skeleton_calls:
        line_indent = re.match(r'^(\s*)', line).group(1)
        for call in skeleton_calls[idx]:
            sys.stdout.write(f"\t{line_indent}→ {call}()\n")
PY
